        local output_lines=()
        local max_output_lines=8

        shopt -s lastpipe

        SIGNAL=0

        trap 'SIGNAL=2' SIGINT

        SECONDS=0
        docker exec -e "TZ=Europe/Berlin" ${ENV_ARGS[@]} --workdir "/git/$CUR_DIR" $CONTAINER_ID "$@" 2>&1 | while IFS= read FULL_LINE; do
            NUM_COLS=$(tput cols)
            NUM_COLS=$(($NUM_COLS - 7))

            FULL_LINE="$(echo -en "$FULL_LINE")"
            NEW_LINE="${FULL_LINE:0:$NUM_COLS}"
            FULL_LINE="${FULL_LINE:$NUM_COLS}"

            while [ ! -z "$NEW_LINE" ]; do
                OUTPUT=1
                OUTPUT_CONTENT=""
                # Reprint last n-1 lines
                if [ $output_line_no -ne $last_output_line_no ]; then
                    if [ $output_line_no -gt 0 ]; then
                        for line_index in $(seq $((output_line_no - 1))); do
                            OUTPUT_CONTENT="$OUTPUT_CONTENT\033[F"
                        done
                        for output_line in "${output_lines[@]}"; do
                            length=${#output_line}
                            empty_string="$(printf '%*s' "$length" '')"
                            OUTPUT_CONTENT="$OUTPUT_CONTENT\r    $COLORΓöé$RESET $empty_string\n"
                        done
                        if [ $output_line_no -gt $(($max_output_lines - 1)) ]; then
                            output_lines=("${output_lines[@]:1}")
                            output_line_no=$max_output_lines
                        fi
                        for line_index in $(seq $output_line_no); do
                            OUTPUT_CONTENT="$OUTPUT_CONTENT\033[F\r"
                        done
                        for output_line in "${output_lines[@]}"; do
                            OUTPUT_CONTENT="$OUTPUT_CONTENT\r    $COLORΓöé$RESET $output_line\n"
                        done
                        OUTPUT_CONTENT="$OUTPUT_CONTENT\r    $COLORΓöé$RESET "
                    fi
                    last_output_line_no=$output_line_no
                fi

                if [ ! -z "$NEW_LINE" ]; then
                    OUTPUT_CONTENT="$OUTPUT_CONTENT\r    $COLORΓöé$RESET $NEW_LINE"
                    output_lines+=("$NEW_LINE")
                    if [ $output_line_no -lt $(($max_output_lines)) ]; then
                        output_line_no=$(($output_line_no + 1))
                    else
                        last_output_line_no=0
                    fi

                    echo "$NEW_LINE" >> $LOG_FILE

                    LOG_SIZE=$(du -b "$LOG_FILE" | tr "\t" " " | cut -f1 -d' ')
                    if [ $LOG_SIZE -gt 2097152 ]; then
                        mv $LOG_FILE ${LOG_FILE}.1
                    fi
                else
                    OUTPUT_CONTENT="$OUTPUT_CONTENT\r    $COLORΓöé$RESET                                                                                               "
                fi
                echo -ne "$OUTPUT_CONTENT\r"

                NEW_LINE="${FULL_LINE:0:$NUM_COLS}"
                FULL_LINE="${FULL_LINE:$NUM_COLS}"
            done

            NEW_LINE=""
            FULL_LINE=""
        done
        EXIT_CODE1=$((${PIPESTATUS[0]}))
        EXIT_CODE2=$((${PIPESTATUS[0]}))
