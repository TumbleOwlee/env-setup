            EXIT_CODE=$SIGNAL
        elif [ $EXIT_CODE1 -lt 128 ] && [ $EXIT_CODE1 -gt 0 ]; then
            EXIT_CODE=$EXIT_CODE1
        elif [ $EXIT_CODE1 -ne 0 ]; then
            EXIT_CODE=$(($EXIT_CODE1 - 128))
        elif [ $EXIT_CODE2 -lt 128 ] && [ $EXIT_CODE2 -gt 0 ]; then
            EXIT_CODE=$EXIT_CODE2
        elif [ $EXIT_CODE2 -ne 0 ]; then
            EXIT_CODE=$(($EXIT_CODE2 - 128))
        fi
        EXEC_PID=$(echo $(docker top $CONTAINER_ID | grep "$CMD" 2>/dev/null | grep -v grep) | cut -f2 -d' ')
        if [ ! -z "$EXEC_PID" ]; then
